<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="${applicationId}.permission.JPUSH_MESSAGE" />

    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" android:host="qun.qq.com" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" android:host="t.me" />
        </intent>
        <package android:name="tv.danmaku.bili" />
    </queries>

    <application
        android:name=".AnimeTrackApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AnimeTrack"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AnimeTrack.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- JPush SDK Service -->
        <service
            android:name=".push.PushService"
            android:enabled="true"
            android:exported="false"
            android:process=":pushcore">
            <intent-filter>
                <action android:name="cn.jiguang.user.service.action" />
            </intent-filter>
        </service>

        <!-- JPush SDK Receiver -->
        <receiver
            android:name=".push.PushReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="cn.jpush.android.intent.RECEIVER_MESSAGE" />
                <category android:name="${applicationId}" />
            </intent-filter>
        </receiver>

        <!-- OPPO 厂商推送：使用字符串资源避免纯数字被解析为 Integer -->
        <meta-data
            android:name="OPPO_APPKEY"
            android:value="@string/oppo_appkey"
            tools:node="replace" />
        <meta-data
            android:name="OPPO_APPID"
            android:value="@string/oppo_appid"
            tools:node="replace" />
        <meta-data
            android:name="OPPO_APPSECRET"
            android:value="@string/oppo_appsecret"
            tools:node="replace" />

        <!-- VIVO 厂商推送：使用字符串资源避免纯数字被解析为 Integer -->
        <meta-data
            android:name="com.vivo.push.api_key"
            android:value="@string/vivo_appkey"
            tools:node="replace" />
        <meta-data
            android:name="com.vivo.push.app_id"
            android:value="@string/vivo_appid"
            tools:node="replace" />

        <!-- 魅族厂商推送：使用字符串资源避免纯数字被解析为 Integer -->
        <meta-data
            android:name="MEIZU_APPKEY"
            android:value="@string/meizu_appkey"
            tools:node="replace" />
        <meta-data
            android:name="MEIZU_APPID"
            android:value="@string/meizu_appid"
            tools:node="replace" />
    </application>

</manifest>
